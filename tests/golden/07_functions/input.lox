fun greet(name) {
    print "Hello, " + name + "!";
}
greet("Alice");
greet("Bob");

fun add(a, b) {
    return a + b;
}
print add(3, 4);

// Recursion
fun fib(n) {
    if (n <= 1) return n;
    return fib(n - 1) + fib(n - 2);
}
print fib(0);
print fib(1);
print fib(7);
print fib(10);

// No explicit return returns nil
fun nothing() {}
print nothing();
